{
    "policy_map": {
        "test_pol": {
            "enable_bcf": false,
            "bcf_prob": 100,
            "bcf_times": 1,
            "enable_fla": true,
            "enable_split": false,
            "split_n": 2,
            "enable_sub": false,
            "sub_times": 1
        },
        "test_dump": {
            "enable_fla": true,
            "dump": true
        }
    },
    "policies": [
        {
            "module": ".*",
            "func": ".*",
            "policy": "test_pol"
        },
        {
            "module": "test.c",
            "func": "main",
            "policy": "test_dump"
        }
    ]
}

